-- سرویس‌های محلی برای حداکثر سرعت
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- بارگذاری کتابخانه
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای محلی پایه
local LocalPlayer = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- متغیرهای فیزیک برای مدیریت حرکت نرم
local OrbitConnection = nil
local OrbitBv = nil

-- ایجاد پنجره
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - Smooth PVP",
    Icon   = "zap",
    Author = "by Vitex",
    Theme = "Violet",
    Acrylic = true,
})

local MainTab = Window:Tab({
    Title = "PVP Smooth",
    Icon = "swords",
})

-- تابع پاکسازی (توقف آنی)
local function StopOrbit()
    if OrbitConnection then OrbitConnection:Disconnect() OrbitConnection = nil end
    if OrbitBv then OrbitBv:Destroy() OrbitBv = nil end
    
    local MyChar = LocalPlayer.Character
    if MyChar then
        for _, v in pairs(MyChar:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = true end
        end
    end
end

-- لیست پلیرها
local function UpdateList()
    local List = {}
    local AllP = Players:GetPlayers()
    for i = 1, #AllP do
        local p = AllP[i]
        if p ~= LocalPlayer then table.insert(List, p.Name) end
    end
    return List
end

local PlayerDrop = MainTab:Dropdown({
    Title = "انتخاب هدف",
    Multi = false,
    Options = UpdateList(),
    Callback = function(v) SelectedPlayerName = v end
})

MainTab:Button({
    Title = "آپدیت لیست",
    Callback = function() PlayerDrop:Refresh(UpdateList()) end
})

-- منطق حرکت نرم و مستقیم (Real-time Orbit)
local function StartOrbit()
    StopOrbit() -- اطمینان از نبود اتصال قبلی
    
    local Angle = 0
    local Speed = 300 -- سرعت جابجایی
    
    OrbitConnection = RunService.Stepped:Connect(function(_, DeltaTime)
        if not IsOrbiting or SelectedPlayerName == "" then 
            StopOrbit()
            return 
        end
        
        local TargetPlayer = Players:FindFirstChild(SelectedPlayerName)
        local TargetRoot = TargetPlayer and TargetPlayer.Character and TargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        local MyChar = LocalPlayer.Character
        local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
        
        if TargetRoot and MyRoot then
            -- نول کلیپ دائم
            for _, p in pairs(MyChar:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
            
            -- بی وزنی
            if not OrbitBv or OrbitBv.Parent ~= MyRoot then
                if OrbitBv then OrbitBv:Destroy() end
                OrbitBv = Instance.new("BodyVelocity")
                OrbitBv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                OrbitBv.Velocity = Vector3.new(0, 0, 0)
                OrbitBv.Parent = MyRoot
            end
            
            -- محاسبه چرخش در لحظه
            Angle = Angle + (DeltaTime * 5) -- سرعت دوران دور پلیر
            local Offset = Vector3.new(math.cos(Angle) * 15, 20, math.sin(Angle) * 15)
            local TargetPos = TargetRoot.Position + Offset
            
            -- حرکت مستقیم و نرم به جای Tween (بدون تیکه تیکه شدن)
            MyRoot.CFrame = MyRoot.CFrame:Lerp(CFrame.new(TargetPos, TargetRoot.Position), 0.2)
        else
            StopOrbit()
        end
    end)
end

MainTab:Toggle({
    Title = "تعقیب نرم (Real-time Orbit)",
    Value = false,
    Callback = function(State)
        IsOrbiting = State
        if State then StartOrbit() else StopOrbit() end
    end
})

-- حمله خودکار با ریموت فیکس شده
MainTab:Toggle({
    Title = "حمله خودکار (Fast Attack)",
    Value = false,
    Callback = function(State)
        FastAttackEnabled = State
        if State then
            task.spawn(function()
                local RegHit = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterHit")
                local RegAtk = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterAttack")
                
                while FastAttackEnabled do
                    local Char = LocalPlayer.Character
                    local Tool = Char and Char:FindFirstChildOfClass("Tool")
                    if Tool then
                        local TargetP = Players:FindFirstChild(SelectedPlayerName)
                        local TRoot = TargetP and TargetP.Character and TargetP.Character:FindFirstChild("HumanoidRootPart")
                        
                        if TRoot and (TRoot.Position - Char.HumanoidRootPart.Position).Magnitude < 100 then
                            RegAtk:FireServer(0.4)
                            local Args = {[1] = Instance.new("MeshPart", nil), [2] = {}, [4] = "694e8177"}
                            RegHit:FireServer(unpack(Args))
                        end
                    end
                    task.wait(0.05) -- سرعت حمله بالا
                end
            end)
        end
    end
})
