-- تعریف سرویس‌های اصلی (Local)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- بارگذاری کتابخانه WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای کنترلی اسکریپت
local lp = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- مدیریت فیزیک و اتصالات
local currentOrbitConnection = nil
local currentOrbitBv = nil

-- ۱. ایجاد پنجره اصلی (Local)
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - Fruit Support",
    Icon   = "apple",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

-- ۲. ایجاد تب اصلی (Local)
local MainTab = Window:Tab({
    Title = "Combat & Speed",
    Icon = "swords",
})

-- تابع لیست پلیرها
local function GetPlayerList()
    local list = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then table.insert(list, p.Name) end
    end
    return list
end

-- ۳. ایجاد دراپ‌دان (Local)
local PlayerDrop = MainTab:Dropdown({
    Title = "انتخاب هدف",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(v) SelectedPlayerName = v end
})

-- ۴. دکمه رفرش لیست (Local)
local RefreshBtn = MainTab:Button({
    Title = "بروزرسانی لیست پلیرها",
    Callback = function() PlayerDrop:Refresh(GetPlayerList()) end
})

-- تابع پاکسازی فیزیک
local function StopMovement()
    if currentOrbitConnection then currentOrbitConnection:Disconnect() currentOrbitConnection = nil end
    if currentOrbitBv then currentOrbitBv:Destroy() currentOrbitBv = nil end
    local char = lp.Character
    if char then
        for _, p in pairs(char:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide = true end
        end
    end
end

-- ۵. تعقیب مربعی بالای سر
local OrbitToggle = MainTab:Toggle({
    Title = "تعقیب مربعی (Above Head)",
    Value = false,
    Callback = function(state)
        IsOrbiting = state
        if not state then StopMovement() return end
        
        local timer = 0
        currentOrbitConnection = RunService.Stepped:Connect(function(_, deltaTime)
            local target = Players:FindFirstChild(SelectedPlayerName)
            local char = lp.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = char and char:FindFirstChild("HumanoidRootPart")

            if tRoot and myRoot and hum then
                if hum.Sit then hum.Sit = false hum.Jump = true end
                for _, p in pairs(char:GetDescendants()) do
                    if p:IsA("BasePart") then p.CanCollide = false end
                end

                if not currentOrbitBv or currentOrbitBv.Parent ~= myRoot then
                    if currentOrbitBv then currentOrbitBv:Destroy() end
                    local bv = Instance.new("BodyVelocity")
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bv.Velocity = Vector3.new(0, 0, 0)
                    bv.Parent = myRoot
                    currentOrbitBv = bv
                end

                timer = timer + (deltaTime * 5)
                local size = 5
                local x = math.clamp(math.cos(timer) * 10, -size, size)
                local z = math.clamp(math.sin(timer) * 10, -size, size)
                
                local heightOffset = 5 
                local targetPos = tRoot.Position + Vector3.new(x, heightOffset, z)
                myRoot.CFrame = myRoot.CFrame:Lerp(CFrame.new(targetPos, tRoot.Position), 0.5)
            else
                StopMovement()
            end
        end)
    end
})

-- ۶. حمله خودکار (Combat + Fruit Support)
local AttackToggle = MainTab:Toggle({
    Title = "حمله خودکار (Combat + Fruit)",
    Value = false,
    Callback = function(state)
        FastAttackEnabled = state
        if state then
            task.spawn(function()
                -- توابع پیدا کردن ریموت‌های عمومی
                local function findRemote(parent, keyword)
                    if not parent then return nil end
                    for _, v in pairs(parent:GetDescendants()) do
                        if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and v.Name:lower():find(keyword:lower()) then
                            return v
                        end
                    end
                end

                local lastRef = 0
                local rAtk, rHit, r874

                while FastAttackEnabled do
                    pcall(function()
                        local char = lp.Character
                        local tool = char and char:FindFirstChildOfClass("Tool")
                        
                        if char and tool then
                            -- الف) بخش Fruit Attack (اختصاصی برای میوه‌ها)
                            local FruitRemote = tool:FindFirstChild("LeftClickRemote")
                            if FruitRemote then
                                -- ارسال مختصات به سمت هدف
                                local target = Players:FindFirstChild(SelectedPlayerName)
                                local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
                                if tRoot then
                                    local direction = (tRoot.Position - char.HumanoidRootPart.Position).Unit
                                    FruitRemote:FireServer(direction, 4)
                                end
                            end

                            -- ب) بخش Combat Attack (ریموت‌های عمومی بازی)
                            if tick() - lastRef > 5 then
                                local net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
                                rAtk = findRemote(net, "RegisterAttack")
                                rHit = findRemote(net, "RegisterHit")
                                local rFolder = ReplicatedStorage:FindFirstChild("Remotes")
                                r874 = rFolder and rFolder:FindFirstChildOfClass("RemoteEvent")
                                lastRef = tick()
                            end

                            if rAtk then rAtk:FireServer(0.4) end

                            local function Damage(targetModel)
                                local tRoot = targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Head")
                                if tRoot and (tRoot.Position - char.HumanoidRootPart.Position).Magnitude < 70 then
                                    if rHit then rHit:FireServer(tRoot, {}, nil, "694ba46d") end
                                    if r874 then r874:FireServer("VA+VacmwpavLmp", 13064117, tRoot, {}, "869bada7") end
                                end
                            end

                            -- اعمال دمیج به همه
                            if workspace:FindFirstChild("Enemies") then
                                for _, e in pairs(workspace.Enemies:GetChildren()) do Damage(e) end
                            end
                            for _, p in pairs(Players:GetPlayers()) do
                                if p ~= lp and p.Character then Damage(p.Character) end
                            end
                        end
                    end)
                    task.wait(0.1) -- سرعت اتک
                end
            end)
        end
    end
})
