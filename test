-- تعریف سرویس‌های اصلی به صورت محلی
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

-- بارگذاری کتابخانه WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای پایه و وضعیت‌ها
local LocalPlayer = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- ریفرنس به ریموت‌های اصلی
local NetFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net")
local RegisterHit = NetFolder:WaitForChild("RE/RegisterHit")
local RegisterAttack = NetFolder:WaitForChild("RE/RegisterAttack")

-- ایجاد پنجره اصلی
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - V3",
    Icon   = "crosshair",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

-- ایجاد تب اصلی
local MainTab = Window:Tab({
    Title = "Player Orbit & Kill",
    Icon = "target",
})

-- تابع محلی برای گرفتن لیست پلیرها
local function GetPlayerList()
    local List = {}
    local AllPlayers = Players:GetPlayers()
    for i = 1, #AllPlayers do
        local p = AllPlayers[i]
        if p ~= LocalPlayer then
            table.insert(List, p.Name)
        end
    end
    return List
end

-- دراپ‌دان انتخاب پلیر
local PlayerDropdown = MainTab:Dropdown({
    Title = "انتخاب هدف",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(Selected)
        SelectedPlayerName = Selected
    end
})

-- دکمه رفرش لیست
local RefreshBtn = MainTab:Button({
    Title = "بروزرسانی لیست پلیرها",
    Callback = function()
        local NewList = GetPlayerList()
        PlayerDropdown:Refresh(NewList)
    end
})

-- سیستم چرخش (Orbit) بالای سر پلیر
task.spawn(function()
    local Angle = 0
    while true do
        if IsOrbiting and SelectedPlayerName ~= "" then
            local TargetPlayer = Players:FindFirstChild(SelectedPlayerName)
            local TargetChar = TargetPlayer and TargetPlayer.Character
            local TargetRoot = TargetChar and TargetChar:FindFirstChild("HumanoidRootPart")
            
            local MyChar = LocalPlayer.Character
            local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")

            if TargetRoot and MyRoot then
                Angle = Angle + math.rad(10) -- سرعت چرخش دورانی
                -- تنظیم موقعیت: چرخش با شعاع 12 و ارتفاع 18 واحد بالای سر هدف
                local Offset = Vector3.new(math.cos(Angle) * 12, 18, math.sin(Angle) * 12)
                local TargetPos = TargetRoot.Position + Offset
                
                local Distance = (MyRoot.Position - TargetPos).Magnitude
                local Speed = 300 -- سرعت جابجایی (بالای 250)
                local Time = Distance / Speed

                local Info = TweenInfo.new(Time, Enum.EasingStyle.Linear)
                local OrbitTween = TweenService:Create(MyRoot, Info, {CFrame = CFrame.new(TargetPos, TargetRoot.Position)})
                OrbitTween:Play()
                OrbitTween.Completed:Wait()
            end
        end
        task.wait()
    end
end)

-- تاگل چرخش
local OrbitToggle = MainTab:Toggle({
    Title = "چرخش و تعقیب (Orbit)",
    Value = false,
    Callback = function(State)
        IsOrbiting = State
        if not State then
            local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if MyRoot then
                local StopTween = TweenService:Create(MyRoot, TweenInfo.new(0.05), {CFrame = MyRoot.CFrame})
                StopTween:Play()
            end
        end
    end
})

-- سیستم حمله خودکار با ریموت جدید
local AttackToggle = MainTab:Toggle({
    Title = "حمله خودکار (Fast Attack)",
    Value = false,
    Callback = function(State)
        FastAttackEnabled = State
        
        if State then
            task.spawn(function()
                while FastAttackEnabled do
                    local MyChar = LocalPlayer.Character
                    local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
                    local Tool = MyChar and MyChar:FindFirstChildOfClass("Tool")

                    if MyRoot and Tool then
                        local TargetPlayer = Players:FindFirstChild(SelectedPlayerName)
                        local TargetChar = TargetPlayer and TargetPlayer.Character
                        local TargetRoot = TargetChar and TargetChar:FindFirstChild("HumanoidRootPart")
                        
                        -- چک کردن فاصله (فقط اگر نزدیک هدف بودیم حمله کن)
                        if TargetRoot and (TargetRoot.Position - MyRoot.Position).Magnitude < 100 then
                            -- ۱. ریجستر کردن انیمیشن حمله
                            RegisterAttack:FireServer(0.4)
                            
                            -- ۲. ارسال ریموت دمیج (دقیقاً طبق سورسی که دادی)
                            local HitArgs = {
                                [1] = Instance.new("MeshPart", nil),
                                [2] = {},
                                [4] = "694e8177"
                            }
                            RegisterHit:FireServer(unpack(HitArgs))
                        end
                    end
                    task.wait(0.1) -- سرعت تکرار حمله
                end
            end)
        end
    end
})
