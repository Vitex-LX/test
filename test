-- سرویس‌های محلی
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- بارگذاری WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای کنترلی محلی
local LocalPlayer = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- متغیرهای مدیریت فیزیک (برای توقف فوری)
local currentOrbitTween
local currentBv
local currentNoclip

-- ایجاد پنجره
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - V4",
    Icon   = "target",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

local MainTab = Window:Tab({
    Title = "PVP Control",
    Icon = "swords",
})

-- تابع پاکسازی فیزیک و توقف حرکت
local function cancelOrbit()
    if currentOrbitTween then currentOrbitTween:Cancel() currentOrbitTween = nil end
    if currentBv then currentBv:Destroy() currentBv = nil end
    if currentNoclip then currentNoclip:Disconnect() currentNoclip = nil end
    
    local char = LocalPlayer.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

-- تابع گرفتن لیست پلیرها
local function GetPlayerList()
    local List = {}
    local allP = Players:GetPlayers()
    for i = 1, #allP do
        local p = allP[i]
        if p ~= LocalPlayer then table.insert(List, p.Name) end
    end
    return List
end

local PlayerDropdown = MainTab:Dropdown({
    Title = "انتخاب هدف",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(s) SelectedPlayerName = s end
})

MainTab:Button({
    Title = "رفرش لیست",
    Callback = function() PlayerDropdown:Refresh(GetPlayerList()) end
})

-- منطق تعقیب و چرخش (Orbit) با فیزیک پیشرفته
local function startOrbit()
    task.spawn(function()
        local angle = 0
        while IsOrbiting do
            local targetPlayer = Players:FindFirstChild(SelectedPlayerName)
            local targetChar = targetPlayer and targetPlayer.Character
            local targetRoot = targetChar and targetChar:FindFirstChild("HumanoidRootPart")
            
            local myChar = LocalPlayer.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

            if targetRoot and myRoot then
                -- فعال کردن Noclip
                if not currentNoclip then
                    currentNoclip = RunService.Stepped:Connect(function()
                        if myChar then
                            for _, p in pairs(myChar:GetDescendants()) do
                                if p:IsA("BasePart") then p.CanCollide = false end
                            end
                        end
                    end)
                end

                -- بی‌وزن کردن برای جلوگیری از افتادن
                if not currentBv then
                    currentBv = Instance.new("BodyVelocity")
                    currentBv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    currentBv.Velocity = Vector3.new(0, 0, 0)
                    currentBv.Parent = myRoot
                end

                angle = angle + math.rad(15) -- سرعت چرخش دورانی
                local offset = Vector3.new(math.cos(angle) * 15, 20, math.sin(angle) * 15)
                local targetPos = targetRoot.Position + offset
                
                -- Tween به موقعیت جدید
                local dist = (myRoot.Position - targetPos).Magnitude
                local duration = dist / 300 -- سرعت 300
                
                currentOrbitTween = TweenService:Create(myRoot, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                    CFrame = CFrame.new(targetPos, targetRoot.Position)
                })
                currentOrbitTween:Play()
                currentOrbitTween.Completed:Wait()
            else
                task.wait(0.5)
            end
            task.wait()
        end
        cancelOrbit()
    end)
end

MainTab:Toggle({
    Title = "تعقیب و چرخش (Advanced)",
    Value = false,
    Callback = function(state)
        IsOrbiting = state
        if state then
            startOrbit()
        else
            cancelOrbit()
        end
    end
})

-- حمله خودکار با ریموت MeshPart شما
MainTab:Toggle({
    Title = "حمله خودکار (Fast Attack)",
    Value = false,
    Callback = function(state)
        FastAttackEnabled = state
        if state then
            task.spawn(function()
                local regHit = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterHit")
                local regAtk = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Net"):WaitForChild("RE/RegisterAttack")
                
                while FastAttackEnabled do
                    local char = LocalPlayer.Character
                    local tool = char and char:FindFirstChildOfClass("Tool")
                    if tool then
                        local targetPlayer = Players:FindFirstChild(SelectedPlayerName)
                        local targetRoot = targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                        
                        if targetRoot and (targetRoot.Position - char.HumanoidRootPart.Position).Magnitude < 100 then
                            regAtk:FireServer(0.4)
                            local args = {
                                [1] = Instance.new("MeshPart", nil),
                                [2] = {},
                                [4] = "694e8177"
                            }
                            regHit:FireServer(unpack(args))
                        end
                    end
                    task.wait(0.1)
                end
            end)
        end
    end
})
