-- سرویس‌های اصلی
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- بارگذاری کتابخانه WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای کنترلی
local lp = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- مدیریت فیزیک
local currentOrbitConnection = nil
local currentOrbitBv = nil

-- ۱. ایجاد پنجره (Local)
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - Precise Combat",
    Icon   = "target",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

-- ۲. ایجاد تب (Local)
local MainTab = Window:Tab({
    Title = "PVP Precise",
    Icon = "crosshair",
})

-- تابع لیست پلیرها
local function GetPlayerList()
    local list = {}
    local allP = Players:GetPlayers()
    for i = 1, #allP do
        local p = allP[i]
        if p ~= lp then table.insert(list, p.Name) end
    end
    return list
end

-- ۳. ایجاد دراپ‌دان (Local)
local PlayerDrop = MainTab:Dropdown({
    Title = "انتخاب هدف (Target)",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(v) SelectedPlayerName = v end
})

-- ۴. دکمه رفرش (Local)
local RefreshBtn = MainTab:Button({
    Title = "آپدیت لیست",
    Callback = function() PlayerDrop:Refresh(GetPlayerList()) end
})

-- تابع توقف حرکت
local function StopMovement()
    if currentOrbitConnection then currentOrbitConnection:Disconnect() currentOrbitConnection = nil end
    if currentOrbitBv then currentOrbitBv:Destroy() currentOrbitBv = nil end
    local char = lp.Character
    if char then
        local des = char:GetDescendants()
        for i = 1, #des do
            if des[i]:IsA("BasePart") then des[i].CanCollide = true end
        end
    end
end

-- ۵. تاگل تعقیب چسبیده و دقیق (Local)
local OrbitToggle = MainTab:Toggle({
    Title = "تعقیب چسبیده (Head-Level Orbit)",
    Value = false,
    Callback = function(state)
        IsOrbiting = state
        if not state then 
            StopMovement() 
            return 
        end
        
        local angle = 0
        currentOrbitConnection = RunService.Stepped:Connect(function(_, deltaTime)
            local target = Players:FindFirstChild(SelectedPlayerName)
            local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            local tHead = target and target.Character and target.Character:FindFirstChild("Head")
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            local myChar = lp.Character

            if tRoot and tHead and myRoot then
                -- Noclip
                local parts = myChar:GetDescendants()
                for i = 1, #parts do
                    if parts[i]:IsA("BasePart") then parts[i].CanCollide = false end
                end

                -- Anti-Gravity
                if not currentOrbitBv or currentOrbitBv.Parent ~= myRoot then
                    if currentOrbitBv then currentOrbitBv:Destroy() end
                    local bv = Instance.new("BodyVelocity")
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bv.Velocity = Vector3.new(0, 0, 0)
                    bv.Parent = myRoot
                    currentOrbitBv = bv
                end

                -- تنظیم موقعیت: نزدیک‌تر و در سطح سر (Y = 1.5)
                angle = angle + (deltaTime * 8)
                local radius = 6 -- خیلی نزدیک
                local heightOffset = 1.5 -- دقیقاً هم‌سطح سر و گردن
                local offset = Vector3.new(math.cos(angle) * radius, heightOffset, math.sin(angle) * radius)
                
                -- نگاه کردن مستقیم به سر پلیر
                local targetPos = tRoot.Position + offset
                myRoot.CFrame = myRoot.CFrame:Lerp(CFrame.new(targetPos, tHead.Position), 0.3)
            else
                StopMovement()
            end
        end)
    end
})

-- ۶. تاگل حمله داینامیک (Local)
local AttackToggle = MainTab:Toggle({
    Title = "حمله خودکار (Dynamic)",
    Value = false,
    Callback = function(state)
        FastAttackEnabled = state
        if state then
            task.spawn(function()
                -- توابع جستجوی ریموت
                local function findRemote(parent, keyword)
                    if not parent then return nil end
                    local des = parent:GetDescendants()
                    for i = 1, #des do
                        if (des[i]:IsA("RemoteEvent") or des[i]:IsA("RemoteFunction")) and des[i].Name:lower():find(keyword:lower()) then
                            return des[i]
                        end
                    end
                end

                local function getRemotes()
                    local net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
                    local atk = findRemote(net, "RegisterAttack")
                    local hit = findRemote(net, "RegisterHit")
                    local rFolder = ReplicatedStorage:FindFirstChild("Remotes")
                    local r874 = rFolder and rFolder:FindFirstChildOfClass("RemoteEvent")
                    return atk, hit, r874
                end

                local lastRef = 0
                local rAtk, rHit, r874

                while FastAttackEnabled do
                    pcall(function()
                        if tick() - lastRef > 5 then
                            rAtk, rHit, r874 = getRemotes()
                            lastRef = tick()
                        end

                        local root = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
                        if root and lp.Character:FindFirstChildOfClass("Tool") then
                            if rAtk then rAtk:FireServer(0.4) end

                            local function Damage(targetModel)
                                local tRoot = targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Head")
                                local hum = targetModel:FindFirstChild("Humanoid")
                                if tRoot and hum and hum.Health > 0 and (tRoot.Position - root.Position).Magnitude < 60 then
                                    if rHit then rHit:FireServer(tRoot, {}, nil, "694ba46d") end
                                    if r874 then r874:FireServer("VA+VacmwpavLmp", 13064117, tRoot, {}, "869bada7") end
                                end
                            end

                            -- اتک به NPC
                            local enemies = workspace:FindFirstChild("Enemies")
                            if enemies then
                                local eList = enemies:GetChildren()
                                for i = 1, #eList do Damage(eList[i]) end
                            end
                            -- اتک به پلیر هدف
                            local targetPlr = Players:FindFirstChild(SelectedPlayerName)
                            if targetPlr and targetPlr.Character then Damage(targetPlr.Character) end
                        end
                    end)
                    task.wait(0.1)
                end
            end)
        end
    end
})
