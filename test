-- تعریف سرویس‌های اصلی (Local)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

-- بارگذاری کتابخانه WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای کنترلی اسکریپت (Local)
local lp = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- متغیرهای فیزیک و حرکت
local currentOrbitConnection = nil
local currentOrbitBv = nil

-- ایجاد پنجره اصلی
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - Final Boss",
    Icon   = "shield-check",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

local MainTab = Window:Tab({
    Title = "Combat & Orbit",
    Icon = "swords",
})

--- [ بخش مدیریت لیست پلیرها ] ---
local function GetPlayerList()
    local list = {}
    local all = Players:GetPlayers()
    for i = 1, #all do
        local p = all[i]
        if p ~= lp then table.insert(list, p.Name) end
    end
    return list
end

local PlayerDrop = MainTab:Dropdown({
    Title = "انتخاب هدف",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(v) SelectedPlayerName = v end
})

MainTab:Button({
    Title = "بروزرسانی لیست",
    Callback = function() PlayerDrop:Refresh(GetPlayerList()) end
})

--- [ بخش حرکت هوشمند و نرم (Smooth Orbit) ] ---
local function StopOrbit()
    if currentOrbitConnection then currentOrbitConnection:Disconnect() currentOrbitConnection = nil end
    if currentOrbitBv then currentOrbitBv:Destroy() currentOrbitBv = nil end
    local char = lp.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

local function StartOrbit()
    StopOrbit()
    local angle = 0
    currentOrbitConnection = RunService.Stepped:Connect(function(_, deltaTime)
        if not IsOrbiting or SelectedPlayerName == "" then StopOrbit() return end
        
        local target = Players:FindFirstChild(SelectedPlayerName)
        local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        local myChar = lp.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

        if tRoot and myRoot then
            -- Noclip
            for _, v in pairs(myChar:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
            -- Anti-Gravity
            if not currentOrbitBv or currentOrbitBv.Parent ~= myRoot then
                if currentOrbitBv then currentOrbitBv:Destroy() end
                currentOrbitBv = Instance.new("BodyVelocity")
                currentOrbitBv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                currentOrbitBv.Velocity = Vector3.new(0, 0, 0)
                currentOrbitBv.Parent = myRoot
            end
            -- Calculation
            angle = angle + (deltaTime * 7)
            local offset = Vector3.new(math.cos(angle) * 14, 18, math.sin(angle) * 14)
            myRoot.CFrame = myRoot.CFrame:Lerp(CFrame.new(tRoot.Position + offset, tRoot.Position), 0.25)
        end
    end)
end

MainTab:Toggle({
    Title = "تعقیب هوشمند (Smooth Orbit)",
    Value = false,
    Callback = function(state)
        IsOrbiting = state
        if state then StartOrbit() else StopOrbit() end
    end
})

--- [ بخش حمله خودکار با ریموت‌های داینامیک ] ---
MainTab:Toggle({
    Title = "حمله خودکار (Dynamic Attack)",
    Value = false,
    Callback = function(state)
        FastAttackEnabled = state
        
        if state then
            task.spawn(function()
                -- توابع داخلی جستجو (Local)
                local function findRemote(parent, keyword)
                    if not parent then return nil end
                    local des = parent:GetDescendants()
                    for i = 1, #des do
                        local v = des[i]
                        if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and v.Name:lower():find(keyword:lower()) then
                            return v
                        end
                    end
                end

                local function getRemoteWithFallback()
                    local Net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
                    local regAttack = findRemote(Net, "RegisterAttack")
                    local regHit = findRemote(Net, "RegisterHit")
                    
                    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
                    local rem874 = nil
                    if remotesFolder then
                        local children = remotesFolder:GetChildren()
                        for i = 1, #children do
                            if children[i]:IsA("RemoteEvent") then rem874 = children[i] break end
                        end
                    end
                    return regAttack, regHit, rem874
                end

                local lastRefresh = 0
                local rAttack, rHit, r874

                while FastAttackEnabled do
                    pcall(function()
                        -- رفرش ریموت‌ها هر ۵ ثانیه
                        if tick() - lastRefresh > 5 then
                            rAttack, rHit, r874 = getRemoteWithFallback()
                            lastRefresh = tick()
                        end

                        local char = lp.Character
                        local root = char and char:FindFirstChild("HumanoidRootPart")
                        local tool = char and char:FindFirstChildOfClass("Tool")

                        if root and tool then
                            -- حمله به NPC ها و پلیر هدف
                            local function DamageTarget(targetModel)
                                local tRoot = targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Head")
                                local hum = targetModel:FindFirstChild("Humanoid")
                                if tRoot and hum and hum.Health > 0 and (tRoot.Position - root.Position).Magnitude < 70 then
                                    
                                    if rAttack then rAttack:FireServer(0.4) end
                                    
                                    -- استفاده از ریموت با MeshPart (دقیقاً طبق سورست)
                                    if rHit then
                                        local hitArgs = {[1] = Instance.new("MeshPart", nil), [2] = {}, [4] = "694ba46d"}
                                        rHit:FireServer(unpack(hitArgs))
                                    end

                                    if r874 then
                                        local args874 = {"VA+VacmwpavLmp", 13064117, tRoot, {}, "869bada7"}
                                        r874:FireServer(unpack(args874))
                                    end
                                end
                            end

                            -- حمله به انیمیشن‌ها (NPCs)
                            local enemies = workspace:FindFirstChild("Enemies")
                            if enemies then
                                local eChildren = enemies:GetChildren()
                                for i = 1, #eChildren do DamageTarget(eChildren[i]) end
                            end

                            -- حمله به پلیر انتخاب شده (Target)
                            local targetPlr = Players:FindFirstChild(SelectedPlayerName)
                            if targetPlr and targetPlr.Character then
                                DamageTarget(targetPlr.Character)
                            end
                        end
                    end)
                    task.wait(0.1)
                end
            end)
        end
    end
})
