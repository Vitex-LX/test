local ValidEvent = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("Validator2")

local IsAutoShootEnabled = false
local LastValidatorKey = 15003121 -- مقدار پیش‌فرض
local LastValidatorArg2 = 16    -- مقدار پیش‌فرض دوم

