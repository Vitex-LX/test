-- تعریف سرویس‌های اصلی به صورت محلی
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- بارگذاری کتابخانه WindUI
local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

-- متغیرهای کنترلی اسکریپت
local lp = Players.LocalPlayer
local SelectedPlayerName = ""
local IsOrbiting = false
local FastAttackEnabled = false

-- متغیرهای مدیریت حرکت
local currentOrbitConnection = nil
local currentOrbitBv = nil

-- ایجاد پنجره اصلی (Local)
local Window = WindUI:CreateWindow({
    Title  = "Vitex Hub - All-In-One",
    Icon   = "shield-check",
    Author = "by Vitex",
    Theme  = "Violet",
    Acrylic = true,
})

-- ایجاد تب اصلی (Local)
local MainTab = Window:Tab({
    Title = "Combat & Orbit",
    Icon = "swords",
})

--- [ تابع محلی برای گرفتن لیست پلیرها ] ---
local function GetPlayerList()
    local list = {}
    local allPlayers = Players:GetPlayers()
    for i = 1, #allPlayers do
        local p = allPlayers[i]
        if p ~= lp then table.insert(list, p.Name) end
    end
    return list
end

-- ایجاد دراپ‌دان (Local)
local PlayerDrop = MainTab:Dropdown({
    Title = "انتخاب هدف برای Orbit",
    Multi = false,
    Options = GetPlayerList(),
    Callback = function(v) SelectedPlayerName = v end
})

-- ایجاد دکمه رفرش لیست (Local)
local RefreshBtn = MainTab:Button({
    Title = "بروزرسانی لیست پلیرها",
    Callback = function() PlayerDrop:Refresh(GetPlayerList()) end
})

--- [ سیستم تعقیب و چرخش نرم ] ---
local function StopOrbit()
    if currentOrbitConnection then currentOrbitConnection:Disconnect() currentOrbitConnection = nil end
    if currentOrbitBv then currentOrbitBv:Destroy() currentOrbitBv = nil end
    local char = lp.Character
    if char then
        local parts = char:GetDescendants()
        for i = 1, #parts do
            local p = parts[i]
            if p:IsA("BasePart") then p.CanCollide = true end
        end
    end
end

local function StartOrbit()
    StopOrbit()
    local angle = 0
    currentOrbitConnection = RunService.Stepped:Connect(function(_, deltaTime)
        if not IsOrbiting or SelectedPlayerName == "" then StopOrbit() return end
        local target = Players:FindFirstChild(SelectedPlayerName)
        local tRoot = target and target.Character and target.Character:FindFirstChild("HumanoidRootPart")
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if tRoot and myRoot then
            angle = angle + (deltaTime * 7)
            local offset = Vector3.new(math.cos(angle) * 14, 18, math.sin(angle) * 14)
            myRoot.CFrame = myRoot.CFrame:Lerp(CFrame.new(tRoot.Position + offset, tRoot.Position), 0.25)
        end
    end)
end

-- ایجاد تاگل چرخش (Local)
local OrbitToggle = MainTab:Toggle({
    Title = "تعقیب هوشمند (Orbit)",
    Value = false,
    Callback = function(state)
        IsOrbiting = state
        if state then StartOrbit() else StopOrbit() end
    end
})

--- [ بخش حمله خودکار (دقیقاً طبق سورسی که دادی) ] ---
-- ایجاد تاگل حمله (Local)
local AttackToggle = MainTab:Toggle({
    Title = "حمله خودکار (NPC & Players)",
    Value = false,
    Callback = function(state)
        FastAttackEnabled = state
        
        if state then
            task.spawn(function()
                -- توابع داخلی جستجوی ریموت (Local)
                local function findRemote(parent, keyword)
                    if not parent then return nil end
                    local des = parent:GetDescendants()
                    for i = 1, #des do
                        local v = des[i]
                        if (v:IsA("RemoteEvent") or v:IsA("RemoteFunction")) and v.Name:lower():find(keyword:lower()) then
                            return v
                        end
                    end
                    return nil
                end

                local function getRemoteWithFallback()
                    local Net = ReplicatedStorage:FindFirstChild("Modules") and ReplicatedStorage.Modules:FindFirstChild("Net")
                    local regAttack = findRemote(Net, "RegisterAttack")
                    local regHit = findRemote(Net, "RegisterHit")
                    
                    local remotesFolder = ReplicatedStorage:FindFirstChild("Remotes")
                    local rem874 = nil
                    if remotesFolder then
                        local children = remotesFolder:GetChildren()
                        for i = 1, #children do
                            if children[i]:IsA("RemoteEvent") then rem874 = children[i] break end
                        end
                    end
                    return regAttack, regHit, rem874
                end

                local lastRemoteRefresh = 0
                local RegisterAttack, RegisterHit, Remote874

                while FastAttackEnabled do
                    pcall(function()
                        -- رفرش ریموت‌ها هر ۵ ثانیه
                        if tick() - lastRemoteRefresh > 5 then
                            RegisterAttack, RegisterHit, Remote874 = getRemoteWithFallback()
                            lastRemoteRefresh = tick()
                        end

                        local character = lp.Character
                        local root = character and character:FindFirstChild("HumanoidRootPart")
                        local tool = character and character:FindFirstChildOfClass("Tool")

                        if root and tool then
                            -- ۱. فعال کردن انیمیشن حمله
                            if RegisterAttack then RegisterAttack:FireServer(0.4) end
                            
                            -- تابع داخلی دمیج زدن
                            local function DamageTarget(targetModel)
                                local tRoot = targetModel:FindFirstChild("HumanoidRootPart") or targetModel:FindFirstChild("Head")
                                local hum = targetModel:FindFirstChild("Humanoid")
                                
                                if tRoot and hum and hum.Health > 0 then
                                    if (tRoot.Position - root.Position).Magnitude < 65 then
                                        -- ریموت اصلی ضربه با کد اختصاصی تو
                                        if RegisterHit then
                                            RegisterHit:FireServer(tRoot, {}, nil, "694ba46d")
                                        end
                                        -- ریموت فرعی ۸۷۴ با آرگومان‌های تو
                                        if Remote874 then
                                            local args = {"VA+VacmwpavLmp", 13064117, tRoot, {}, "869bada7"}
                                            Remote874:FireServer(unpack(args))
                                        end
                                    end
                                end
                            end

                            -- الف) حمله به تمام NPC ها در پوشه Enemies
                            local enemyFolder = workspace:FindFirstChild("Enemies")
                            if enemyFolder then
                                local enemies = enemyFolder:GetChildren()
                                for i = 1, #enemies do DamageTarget(enemies[i]) end
                            end

                            -- ب) حمله به تمام پلیرهای نزدیک (بجز خودت)
                            local allPlrs = Players:GetPlayers()
                            for i = 1, #allPlrs do
                                local p = allPlrs[i]
                                if p ~= lp and p.Character then
                                    DamageTarget(p.Character)
                                end
                            end
                        end
                    end)
                    task.wait(0.1)
                end
            end)
        end
    end
})
