-- [بخش هوشمند: قاپ زدن اعداد متغیر ریموت]
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()
    
    -- اگر بازی داشت ریموت تاییدیه را می‌فرستاد، اعدادش را ذخیره کن
    if not checkcaller() and Self == ValidEvent and Method == "FireServer" then
        LastValidatorKey = Args[1]
        LastValidatorArg2 = Args[2]
    end
    
    return OldNamecall(Self, ...)
end))

-- تابع محلی برای پیدا کردن NPC
local function GetClosestNPC()
    local Target = nil
    local Distance = 1000
    local MyChar = LocalPlayer.Character
    local MyRoot = MyChar and MyChar:FindFirstChild("HumanoidRootPart")
    
    if not MyRoot then return nil end

    local Descendants = game:GetService("Workspace"):GetDescendants()
    for i = 1, #Descendants do
        local v = Descendants[i]
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(v) and v.Humanoid.Health > 0 then
                local Mag = (v.HumanoidRootPart.Position - MyRoot.Position).Magnitude
                if Mag < Distance then
                    Distance = Mag
                    Target = v
                end
            end
        end
    end
    return Target
end

-- حلقه شلیک با اعداد داینامیک
task.spawn(function()
    while task.wait(0.1) do
        if IsAutoShootEnabled then
            local Char = LocalPlayer.Character
            local Tool = Char and Char:FindFirstChildOfClass("Tool")
            
            if Tool then
                local TargetNPC = GetClosestNPC()
                if TargetNPC then
                    local Pos = TargetNPC.HumanoidRootPart.Position
                    
                    -- ارسال تاییدیه با آخرین عددی که از خود بازی گرفتیم
                    ValidEvent:FireServer(LastValidatorKey, LastValidatorArg2)
                    
                    -- شلیک
                    ShootEvent:FireServer(vector.create(Pos.X, Pos.Y, Pos.Z), {})
                end
            end
        end
    end
end)

