-- تابع محلی برای پیدا کردن نزدیک‌ترین NPC
local function GetClosestNPC()
    local Target = nil
    local Distance = 1500 -- شعاع عملکرد
    local MyChar = LocalPlayer.Character
    local MyPos = MyChar and MyChar:FindFirstChild("HumanoidRootPart") and MyChar.HumanoidRootPart.Position

    if not MyPos then return nil end

    -- جستجو در تمام محیط بازی برای پیدا کردن مدل‌های زنده غیر پلیر
    local AllDescendants = game:GetService("Workspace"):GetDescendants()
    for i = 1, #AllDescendants do
        local v = AllDescendants[i]
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("HumanoidRootPart") then
            -- چک کردن اینکه پلیر نباشد و جان داشته باشد
            if not Players:GetPlayerFromCharacter(v) and v.Humanoid.Health > 0 then
                local Mag = (v.HumanoidRootPart.Position - MyPos).Magnitude
                if Mag < Distance then
                    Distance = Mag
                    Target = v
                end
            end
        end
    end
    return Target
end

-- حلقه شلیک خودکار
task.spawn(function()
    while task.wait() do -- اجرای سریع
        if IsAutoShootEnabled then
            local CurrentChar = LocalPlayer.Character
            local Tool = CurrentChar and CurrentChar:FindFirstChildOfClass("Tool")
            
            -- اگر تفنگ دستمون بود (هر تفنگی)
            if Tool then
                local TargetNPC = GetClosestNPC()
                if TargetNPC then
                    local Pos = TargetNPC.HumanoidRootPart.Position
                    
                    -- ارسال ریموت دقیقاً با فرمت ارسالی شما
                    local Args = {
                        [1] = vector.create(Pos.X, Pos.Y, Pos.Z),
                        [2] = {}
                    }
                    ShootEvent:FireServer(unpack(Args))
                end
            end
        end
    end
end)

